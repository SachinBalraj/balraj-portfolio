# Backend API URL
# - Local dev with Vite proxy: leave empty (proxy in vite.config.js handles /api -> localhost:5000)
# - Production (Vercel): set to your deployed Render backend URL (e.g. https://your-app.onrender.com)
# - Without proxy: set to http://localhost:5000
VITE_API_URL=

# Vite dev server port (optional, defaults to 5173)
VITE_PORT=5173

# WhatsApp phone number for contact/consultation notifications (include country code, no +)
VITE_WHATSAPP_PHONE=919842726655
