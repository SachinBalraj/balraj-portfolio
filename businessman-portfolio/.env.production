# Backend API URL
# For UNIFIED deployment (root vercel.json): leave empty — API calls use relative URLs (/api/*, /uploads/*)
# For SPLIT deployment (separate backend project): set to your backend URL
# Example: VITE_API_URL=https://backend-navy-alpha-54.vercel.app
VITE_API_URL=

# Vite dev server port (optional, defaults to 5173)
VITE_PORT=5173

# WhatsApp phone number for contact/consultation notifications (include country code, no +)
VITE_WHATSAPP_PHONE=919842726655
