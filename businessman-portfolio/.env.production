# Backend API URL
# Set this to your deployed backend URL (Render, Railway, Fly.io, etc.)
# Example: https://balraj-portfolio-api.onrender.com
VITE_API_URL=https://your-backend-domain.com

# Vite dev server port (optional, defaults to 5173)
VITE_PORT=5173

# WhatsApp phone number for contact/consultation notifications (include country code, no +)
VITE_WHATSAPP_PHONE=919842726655
