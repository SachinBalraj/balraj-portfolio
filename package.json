{
  "scripts": {
    "dev": "cd businessman-portfolio && npm run dev",
    "build": "cd businessman-portfolio && npm ci --include=dev && npm run build",
    "preview": "cd businessman-portfolio && npm run preview",
    "postinstall": "cd businessman-portfolio && npm install --include=dev",
    "start": "node backend/server.js",
    "build-and-start": "cd businessman-portfolio && npm run build && NODE_ENV=production node ../backend/server.js",
    "serve-frontend-dev": "SERVE_FRONTEND=true node backend/server.js"
  },
  "dependencies": {
    "mongodb": "^7.2.0",
    "recharts": "^3.8.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "xss-clean": "^0.1.4"
  },
  "engines": {
    "node": "^18.0.0 || ^20.0.0"
  }
}
