# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=<random-64-char-hex>
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173,http://localhost:5177

# CSRF secret (used for token generation)
CSRF_SECRET=<random-32-char-hex>

# Production CSP overrides (optional — only needed if backend serves images/assets)
# Comma-separated list of additional origins for img-src and connect-src
CSP_CONNECT_SRC=
CSP_IMG_SRC=

# Email (Gmail SMTP — optional, for contact/consultation notifications)
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
